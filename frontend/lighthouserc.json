{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000/blog/my-first-blog"],

      "startServerCommand": "npm run build && npm run start",

      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 60000
    },

    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "is-on-https": "off"
      }
    }
  }
}